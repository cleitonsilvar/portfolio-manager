                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Response tem id', () => pm.expect(json).to.have.property('id'));",
                  "pm.test('Response tem nome', () => pm.expect(json).to.have.property('nome'));",
                  "pm.test('Response tem atribuicao', () => pm.expect(json).to.have.property('atribuicao'));",
